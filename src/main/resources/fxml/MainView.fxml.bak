<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.polipoli.firebaseapp.MainController"
            styleClass="root-pane">

    <!-- ── TOP BAR ── -->
    <top>
        <VBox styleClass="top-bar">
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="header-row">
                <insets><Insets top="12" right="20" bottom="12" left="20"/></insets>

                <Label text="☁ Firebase Cloud Manager" styleClass="app-title"/>
                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Colección:" styleClass="label-header"/>
                <ComboBox fx:id="collectionCombo" prefWidth="140" styleClass="combo-col"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Buscar por:" styleClass="label-header"/>
                <ComboBox fx:id="searchByCombo" prefWidth="120"/>
                <TextField fx:id="searchField" prefWidth="200" promptText="Valor a buscar…"/>
                <Button fx:id="btnSearch" text="🔍 Buscar" onAction="#searchRecords"
                        styleClass="btn-primary"/>
                <Button fx:id="btnLoadAll" text="↺ Todos" onAction="#loadAllRecords"
                        styleClass="btn-secondary"/>
            </HBox>

            <HBox styleClass="status-bar" alignment="CENTER_LEFT">
                <insets><Insets top="4" right="20" bottom="4" left="20"/></insets>
                <Label fx:id="statusLabel" text="Iniciando conexión a Firebase…"
                       styleClass="status-label"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── CENTER: TABLE ── -->
    <center>
        <VBox styleClass="table-container">
            <insets><Insets top="12" right="16" bottom="8" left="16"/></insets>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <insets><Insets bottom="8"/></insets>
                <Label text="Registros en la nube" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnLoadCsv" text="📂 Cargar CSV → Firebase"
                        onAction="#loadFromCsv" styleClass="btn-csv"/>
            </HBox>
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="data-table"
                       placeholder="&lt;Label text='Sin datos. Carga un CSV o usa el formulario.'/>">
            </TableView>
        </VBox>
    </center>

    <!-- ── RIGHT: FORM PANEL ── -->
    <right>
        <VBox fx:id="formPanel" prefWidth="300" styleClass="form-panel" spacing="0">
            <insets><Insets top="12" right="16" bottom="12" left="12"/></insets>

            <Label fx:id="formTitleLabel" text="➕ Nuevo registro" styleClass="form-title"/>

            <Separator styleClass="form-sep">
                <VBox.margin><Insets top="8" bottom="12"/></VBox.margin>
            </Separator>

            <GridPane fx:id="formGrid" hgap="10" vgap="10" styleClass="form-grid">
                <columnConstraints>
                    <ColumnConstraints minWidth="80" prefWidth="90"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
            </GridPane>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8">
                <VBox.margin><Insets top="16"/></VBox.margin>
                <Button fx:id="btnSave" text="💾 Insertar" onAction="#saveRecord"
                        maxWidth="Infinity" styleClass="btn-save"/>
                <Button fx:id="btnNewRecord" text="＋ Nuevo registro" onAction="#newRecord"
                        maxWidth="Infinity" styleClass="btn-new"/>
                <Button fx:id="btnCancelEdit" text="✖ Cancelar edición" onAction="#cancelEdit"
                        maxWidth="Infinity" styleClass="btn-cancel" visible="false"/>
            </VBox>
        </VBox>
    </right>

</BorderPane>
